package ops.agent

# ---------------------------------------------------------------------------
# Example: argv-based allow-list policy
#
# The policy receives `input.argv` — the proposed command as a list of strings.
# Return `allow = true` for every command the agent is permitted to run.
#
# This example restricts the agent to read-only kubectl and helm operations,
# plus a small set of safe git commands.  Adjust the allow-listed prefixes to
# match the tools and subcommands you want the agent to use.
# ---------------------------------------------------------------------------

default allow = false

# Read-only kubectl subcommands
kubectl_readonly_prefixes := [
    ["kubectl", "get"],
    ["kubectl", "describe"],
    ["kubectl", "logs"],
    ["kubectl", "top"],
    ["kubectl", "explain"],
]

# Read-only helm subcommands
helm_readonly_prefixes := [
    ["helm", "list"],
    ["helm", "status"],
    ["helm", "get"],
    ["helm", "history"],
]

# Safe git subcommands (no push / force operations)
git_safe_prefixes := [
    ["git", "log"],
    ["git", "diff"],
    ["git", "status"],
    ["git", "show"],
]

# Block any command that targets Kubernetes Secret resources, even if the
# subcommand would otherwise be allowed.
targets_secrets {
    input.argv[_] == "secret"
}
targets_secrets {
    input.argv[_] == "secrets"
}

allow {
    not targets_secrets
    some prefix
    prefix := kubectl_readonly_prefixes[_]
    array.slice(input.argv, 0, count(prefix)) == prefix
}

allow {
    some prefix
    prefix := helm_readonly_prefixes[_]
    array.slice(input.argv, 0, count(prefix)) == prefix
}

allow {
    some prefix
    prefix := git_safe_prefixes[_]
    array.slice(input.argv, 0, count(prefix)) == prefix
}