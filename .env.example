# LLM
LLM_BASE_URL=https://your-llm-endpoint
LLM_API_KEY=your-key-here
LLM_MODEL=gpt-4.1

# Agent
MAX_ITERATIONS=10
POLICY_PATH=/path/to/your-policy.rego

# Skills (optional — defaults to ./skills.json in the working directory)
# SKILLS_FILE=./skills.json

# Optional: load skills from a remote public Git repository
# SKILLS_REPO_URL=https://github.com/org/skills-repo
# SKILLS_REPO_BRANCH=main
